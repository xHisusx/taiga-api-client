# Скопируйте этот файл в .env и заполните своими значениями.
# .env загружается автоматически (bun или встроенным fallback-загрузчиком в helpers.ts)
# и не коммитится — он в .gitignore.

# Базовый URL вашего Taiga-инстанса (без /api/v1 — он добавляется автоматически).
# Для Taiga Cloud (SaaS): https://api.taiga.io
#   (tree.taiga.io — это frontend, REST API живёт на отдельном поддомене api.taiga.io)
# Для self-hosted — корень вашего инстанса, например http://localhost:9000
TAIGA_INTEGRATION_URL=https://api.taiga.io

# Логин тестового аккаунта — username ИЛИ email. Taiga API принимает оба.
# ВАЖНО: dedicated тестовый аккаунт. Тесты создают и удаляют проекты.
TAIGA_TEST_USER=user@example.com
TAIGA_TEST_PASSWORD=changeme

# Опционально: slug шаблона проекта. Если не задан, Taiga использует дефолтный.
# TAIGA_TEMPLATE_SLUG=scrum
