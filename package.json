{
  "name": "taiga-api-client",
  "version": "0.1.0",
  "description": "TypeScript client for the Taiga REST API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "taiga",
    "taiga-api",
    "client",
    "rest",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xHisusx/taiga-api-client.git"
  },
  "homepage": "https://github.com/xHisusx/taiga-api-client#readme",
  "bugs": {
    "url": "https://github.com/xHisusx/taiga-api-client/issues"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "packageManager": "bun@1.3.6",
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "msw": "^2",
    "prettier": "^3",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
